# ================================
# REQUIRED - Must be set
# ================================

# Your Gemini API key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Which Gemini model to use
GEMINI_MODEL=gemini-2.5-pro


# ================================
# GENERATION PARAMETERS
# ================================

# Temperature controls randomness (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.2

# Maximum tokens in generated output
MAX_OUTPUT_TOKENS=8192


# ================================
# EMBEDDING & RETRIEVAL
# ================================

# Sentence transformer model for embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Number of top-k documents to retrieve
RETRIEVAL_TOP_K=2

# Chunk size for splitting large documents (0 = no chunking)
CHUNK_SIZE=500


# ================================
# PATHS & OUTPUT
# ================================

# Embedding cache file name
EMBEDDING_CACHE_FILE=embeddings_cache.pkl

# Jurisdiction for contracts
JURISDICTION=England and Wales


# ================================
# DEBUG
# ================================

# Enable debug-level logging
DEBUG=true
